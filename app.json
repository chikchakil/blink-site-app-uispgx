{
  "expo": {
    "name": "Chik-Chak - Beauty Manager",
    "slug": "chik-chak",
    "version": "1.0.0",
    "description": "The smart appointment manager for beauty professionals. Schedule clients, manage services, and grow your business.",
    "orientation": "portrait",
    "icon": "./assets/images/01685194-8938-4717-a6b4-33949729bef6.jpeg",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/natively-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "icon": "./assets/images/01685194-8938-4717-a6b4-33949729bef6.jpeg",
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Natively",
      "requireFullScreen": true,
      "userInterfaceStyle": "light",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Used to capture photos for your profile and appointments",
        "NSPhotoLibraryUsageDescription": "Used to select photos for your profile",
        "NSUserNotificationsUsageDescription": "Get reminders for your upcoming appointments",
        "CFBundleLocalizations": ["en", "fr", "ar", "es"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/01685194-8938-4717-a6b4-33949729bef6.jpeg",
        "backgroundColor": "#FF2D78"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.Natively"
    },
    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser"
    ],
    "scheme": "chikchak",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "supportUrl": "https://chik-chak.com/support",
      "privacyPolicyUrl": "https://chik-chak.com/privacy-policy"
    }
  },
  "scheme": "Blink Site App"
}
